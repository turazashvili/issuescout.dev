# GitHub OAuth App
# Create one at: https://github.com/settings/applications/new
# Homepage URL: http://localhost:3000
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=

# NextAuth Secret (generate with: openssl rand -base64 32)
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# MongoDB Atlas connection string
MONGODB_URI=

# OpenAI API Key (for AI difficulty estimation)
OPENAI_API_KEY=

# Site URL (defaults to localhost for dev; set to your production domain for deployment)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Google Analytics 4 Measurement ID (e.g., G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
